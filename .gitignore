__pycache__/
*.py[cod]
*$py.class

# Test, lint, and type-check caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Packaging artifacts
*.egg-info/
dist/
build/

# Secrets and environment files (NEVER commit!)
.env
.env.*
*.pem
*.key

# OS and IDE files
.DS_Store
.idea/
.vscode/
